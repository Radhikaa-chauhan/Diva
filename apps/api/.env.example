# Copy to .env and fill in for production / real generation.
# Everything below is optional for local dev — omit FLUX_API_KEY to run
# the whole pipeline against the local mock generator.

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/diva
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

ALLOWED_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000

# JWT secret — CHANGE THIS in production to a long random string.
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_PER_HOUR=20

# fal.ai key — set this to switch from the mock generator to real Flux Kontext calls.
FLUX_API_KEY=

# Only needed to run the curation CLI (python -m app.curate), not the deployed app.
ANTHROPIC_API_KEY=

# Hugging Face serverless Inference API credentials
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-schnell