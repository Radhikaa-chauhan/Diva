# Copy to .env and fill in your credentials.

# ── Supabase PostgreSQL Database ──────────────────────────────────────
# Option 1: Direct Connection (Port 5432)
DATABASE_URL=postgresql://postgres:[YOUR_PASSWORD]@db.[YOUR_PROJECT_REF].supabase.co:5432/postgres

# Option 2: Supabase Connection Pooler / Transaction Mode (Port 6543)
# DATABASE_URL=postgresql://postgres.[YOUR_PROJECT_REF]:[YOUR_PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# ── Server Config ─────────────────────────────────────────────────────
ALLOWED_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000

# JWT secret — CHANGE THIS in production to a long random string.
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# Rate limiting
RATE_LIMIT_PER_HOUR=20

# ── Social OAuth ──────────────────────────────────────────────────────
# Google Cloud Console → Credentials → OAuth 2.0 Client ID (Web application).
# Unset = Google sign-in disabled. GitHub needs no backend config.
GOOGLE_CLIENT_ID=

# ── Admin ─────────────────────────────────────────────────────────────
# Comma-separated emails granted admin access (dashboard at /admin).
# Log in with one of these to see the Admin Dashboard.
ADMIN_EMAILS=

# ── Curation (admin "auto-write prompt from image") ───────────────────
# Free Google AI Studio key: https://aistudio.google.com/apikey
# Unset = the manual prompt field still works, only the auto button is off.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# ── Email (SMTP) ──────────────────────────────────────────────────────
# Unset = emails are logged to console instead of sent (dev mode).
# Gmail: smtp.gmail.com + an App Password (Google Account → Security).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=

# ── Image Generation (Hugging Face Inference Providers) ───────────────
# Free monthly inference credits cover this. Model MUST support
# image-to-image so the uploaded selfie actually shapes the output.
HUGGINGFACE_API_KEY=
HUGGINGFACE_MODEL=black-forest-labs/FLUX.1-Kontext-dev
# Dev only: fall back to a local sepia mock instead of failing the job.
ALLOW_MOCK_FALLBACK=false

# Replicate API credentials (Commented out — uncomment if using Replicate)
# REPLICATE_API_TOKEN=
# REPLICATE_MODEL=black-forest-labs/flux-schnell

# fal.ai key (Commented out — uncomment if using fal.ai)
# FLUX_API_KEY=

# Only needed to run the curation CLI (python -m app.curate), not the deployed app.
ANTHROPIC_API_KEY=